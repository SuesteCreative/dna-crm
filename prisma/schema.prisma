generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  password  String?
  role      String   @default("USER")
  image     String?
  partnerId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partner   Partner? @relation(fields: [partnerId], references: [id])
}

model Partner {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  phone      String?
  address    String?
  website    String?
  commission Float     @default(10)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  bookings   Booking[]
  users      User[]
}

model Booking {
  id            String   @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String?
  activityDate  DateTime
  activityTime  String?
  pax           Int      @default(1)
  status        String   @default("CONFIRMED")
  source        String   @default("MANUAL")
  shopifyId     String?  @unique
  totalPrice    Float?
  notes         String?
  activityType  String?
  partnerId     String?
  serviceId     String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orderNumber   String?
  quantity      Int?     @default(1)
  country       String?
  showedUp      Boolean?
  isEdited      Boolean  @default(false)
  originalActivityType String?
  originalPax          Int?
  originalQuantity     Int?
  originalTotalPrice   Float?
  originalActivityDate DateTime?
  originalActivityTime String?
  partner       Partner? @relation(fields: [partnerId], references: [id])
}

model Service {
  id              String   @id @default(cuid())
  shopifyHandle   String?
  name            String
  variant         String?
  sku             String?  @unique
  price           Float?
  imageUrl        String?
  category        String?
  isActive        Boolean  @default(true)
  durationMinutes Int?
  unitCapacity    Int      @default(1)
  capacityGroup   String?
  slotGapMinutes  Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Schedule {
  id        String   @id @default(cuid())
  dayOfWeek Int      @unique // 0=Sunday, 1=Monday, ... 6=Saturday
  openTime  String   // "HH:MM"
  closeTime String   // "HH:MM"
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OverrideLog {
  id          String   @id @default(cuid())
  bookingId   String
  clerkUserId String
  userName    String
  reason      String
  serviceId   String?
  serviceName String?
  slotTime    String
  date        String   // "YYYY-MM-DD"
  createdAt   DateTime @default(now())
}
