generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  password  String?
  role      String   @default("USER")
  image     String?
  partnerId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partner   Partner? @relation(fields: [partnerId], references: [id])
}

model Partner {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  phone      String?
  address    String?
  website    String?
  commission Float     @default(10)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  bookings   Booking[]
  users      User[]
}

model Booking {
  id            String   @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String?
  activityDate  DateTime
  activityTime  String?
  pax           Int      @default(1)
  status        String   @default("CONFIRMED")
  source        String   @default("MANUAL")
  shopifyId     String?  @unique
  totalPrice    Float?
  notes         String?
  activityType  String?
  partnerId     String?
  serviceId     String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orderNumber   String?
  quantity      Int?     @default(1)
  country       String?
  showedUp      Boolean?
  isEdited      Boolean  @default(false)
  originalActivityType String?
  originalPax          Int?
  originalQuantity     Int?
  originalTotalPrice   Float?
  originalActivityDate DateTime?
  originalActivityTime String?
  gcalEventIds         String?  // JSON array of Google Calendar event IDs
  gcalCalendarIds      String?  // JSON array of calendar IDs (parallel to gcalEventIds)
  partner       Partner? @relation(fields: [partnerId], references: [id])
}

model Service {
  id               String   @id @default(cuid())
  shopifyHandle    String?
  name             String
  variant          String?
  sku              String?  @unique
  price            Float?
  imageUrl         String?
  category         String?
  isActive         Boolean  @default(true)
  durationMinutes  Int?
  unitCapacity     Int      @default(1)
  capacityGroup    String?
  slotGapMinutes   Int      @default(10)
  serviceCloseTime String?  // Per-service close time override e.g. "17:40"
  gcalEnabled      Boolean  @default(false)
  minPax           Int?     // Min attendees (pax-priced services, e.g. sofa/banana)
  maxPax           Int?     // Max attendees
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Schedule {
  id        String   @id @default(cuid())
  dayOfWeek Int      @unique // 0=Sunday, 1=Monday, ... 6=Saturday
  openTime  String   // "HH:MM"
  closeTime String   // "HH:MM"
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GcalStaff {
  id         String   @id @default(cuid())
  name       String   // "Jetski 1", "Jetski 2", "Jetski 3", "Sofa/Banana"
  calendarId String   // Google Calendar ID
  serviceId  String?  // Optional: link to a specific Service
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model OverrideLog {
  id          String   @id @default(cuid())
  bookingId   String
  clerkUserId String
  userName    String
  reason      String
  serviceId   String?
  serviceName String?
  slotTime    String
  date        String   // "YYYY-MM-DD"
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String   @default("system")
  userName    String   @default("System")
  action      String   // "CREATE", "UPDATE", "DELETE", "OVERRIDE", "CHECK_IN", etc.
  module      String   // "DASHBOARD", "CONCESSION_ENTRY", "CONCESSION_RESERVATION"
  targetId    String?
  targetName  String?
  details     String?  @db.Text
  createdAt   DateTime @default(now())
}

// ── CONCESSION MODELS ────────────────────────────────────

model Concession {
  id             String   @id @default(cuid())
  slug           String   @unique // "tropico" | "subnauta"
  name           String
  location       String
  rows           Int
  cols           Int
  priceFull      Float
  priceMorning   Float
  priceAfternoon Float
  priceExtraBed  Float
  priceOneBed    Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  spots          ConcessionSpot[]
  entries        ConcessionEntry[]
  reservations   ConcessionReservation[]
}

model ConcessionSpot {
  id           String     @id @default(cuid())
  concessionId String
  concession   Concession @relation(fields: [concessionId], references: [id])
  spotNumber   Int
  row          Int
  col          Int
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  entries      ConcessionEntry[]
  reservations ConcessionReservation[]

  @@unique([concessionId, spotNumber])
}

model ConcessionEntry {
  id            String     @id @default(cuid())
  concessionId  String
  concession    Concession @relation(fields: [concessionId], references: [id])
  spotId        String
  spot          ConcessionSpot @relation(fields: [spotId], references: [id])
  date          String     // "YYYY-MM-DD"
  period        String     // "MORNING" | "AFTERNOON" | "FULL_DAY"
  clientName    String
  clientPhone   String?
  bedConfig     String     @default("TWO_BEDS") // "TWO_BEDS" | "ONE_BED" | "EXTRA_BED"
  totalPrice    Float
  isPaid        Boolean    @default(true)
  notes         String?
  reservationId String?
  reservation   ConcessionReservation? @relation(fields: [reservationId], references: [id])
  isCarryOver   Boolean    @default(false)
  status        String     @default("ACTIVE") // "ACTIVE" | "RELEASED" | "CARRIED_OVER"
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model ConcessionReservation {
  id           String     @id @default(cuid())
  concessionId String
  concession   Concession @relation(fields: [concessionId], references: [id])
  spotId       String
  spot         ConcessionSpot @relation(fields: [spotId], references: [id])
  clientName   String
  clientPhone  String?
  clientEmail  String?
  startDate    String     // "YYYY-MM-DD"
  endDate      String     // "YYYY-MM-DD"
  period       String     // "MORNING" | "AFTERNOON" | "FULL_DAY"
  bedConfig    String     @default("TWO_BEDS")
  totalPrice   Float
  isPaid       Boolean    @default(false)
  notes        String?
  status       String     @default("ACTIVE") // "ACTIVE" | "COMPLETED" | "CANCELLED"
  entries      ConcessionEntry[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
